{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#00000090",
                "editor.background": "#00000090",
                "editor.foreground": "#ccc6d0",
                "text": "#ccc6d0",
                "text.muted": "#ccc6d070",
                "text.ignored": "#ccc6d040",
                "text.placeholder": "#ccc6d050",
                "ignored": "#ccc6d030",
                "element.hover": "#ccc6d030",
                "ghost_element.hover": "#B85E9C30",
                "ghost_element.selected": "#B85E9C30",
                "ghost_element.active": "#B85E9C60",
                "border": "#000000",
                "editor.highlighted_line.background": "#B85E9C10",
                "editor.active_line.background": "#B85E9C10",
                "panel.background": "#00000090",
                "title_bar.background": "#00000090",
                "title_bar.inactive_background": "#00000090",
                "status_bar.background": "#00000090",
                "drop_target.background": "#00000090",
                "elevated_surface.background": "#000000",
                "toolbar.background": "#00000090",
                "tab_bar.background": "#00000090",
                "tab.inactive_background": "#00000090",
                "tab.active_background": "#B85E9C30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#000000",
                "scrollbar.thumb.background": "#B85E9C",
                "editor.gutter.background": "#00000090",
                "terminal.background": "#00000010",
                "terminal.foreground": "#ccc6d0",
                "terminal.dim_foreground": "#ccc6d0",
                "terminal.bright_foreground": "#ccc6d0",
                "terminal.ansi.black": "#000000",
                "terminal.ansi.red": "#B85E9C",
                "terminal.ansi.green": "#93758F",
                "terminal.ansi.yellow": "#7484A1",
                "terminal.ansi.blue": "#AC989D",
                "terminal.ansi.magenta": "#DCADA3",
                "terminal.ansi.cyan": "#D9C9AE",
                "terminal.ansi.white": "#ccc6d0",
                "terminal.ansi.bright_black": "#796c85",
                "terminal.ansi.bright_red": "#B85E9C",
                "terminal.ansi.bright_green": "#93758F",
                "terminal.ansi.bright_yellow": "#7484A1",
                "terminal.ansi.bright_blue": "#AC989D",
                "terminal.ansi.bright_magenta": "#DCADA3",
                "terminal.ansi.bright_cyan": "#D9C9AE",
                "terminal.ansi.bright_white": "#ccc6d0",
                "modified": "#B85E9C",
                "syntax": {
                    "attribute": {
                        "color": "#B85E9C"
                    },
                    "boolean": {
                      "color": "#93758F"
                    },
                    "comment": {
                      "color": "#796c85"
                    },
                    "comment.doc": {
                      "color": "#796c85"
                    },
                    "constant": {
                      "color": "#93758F"
                    },
                    "function": {
                      "color": "#D9C9AE"
                    },
                    "keyword": {
                      "color": "#AC989D"
                    },
                    "number": {
                      "color": "#DCADA3"
                    },
                    "operator": {
                      "color": "#AC989D"
                    },
                    "string": {
                      "color": "#B85E9C"
                    },
                    "variable": {
                      "color": "#93758F"
                    }
                },
                "players": [
                  {
                    "cursor": "#B85E9C",
                    "background": "#000000",
                    "selection": "#B85E9C30"
                  }
                ]
            }
        }
    ]
}
