{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#161e0d90",
                "editor.background": "#161e0d90",
                "editor.foreground": "#c4c6c2",
                "text": "#c4c6c2",
                "text.muted": "#c4c6c270",
                "text.ignored": "#c4c6c240",
                "text.placeholder": "#c4c6c250",
                "ignored": "#c4c6c230",
                "element.hover": "#c4c6c230",
                "ghost_element.hover": "#6B7B8930",
                "ghost_element.selected": "#6B7B8930",
                "ghost_element.active": "#6B7B8960",
                "border": "#161e0d",
                "editor.highlighted_line.background": "#6B7B8910",
                "editor.active_line.background": "#6B7B8910",
                "panel.background": "#161e0d90",
                "title_bar.background": "#161e0d90",
                "title_bar.inactive_background": "#161e0d90",
                "status_bar.background": "#161e0d90",
                "drop_target.background": "#161e0d90",
                "elevated_surface.background": "#161e0d",
                "toolbar.background": "#161e0d90",
                "tab_bar.background": "#161e0d90",
                "tab.inactive_background": "#161e0d90",
                "tab.active_background": "#6B7B8930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#161e0d",
                "scrollbar.thumb.background": "#6B7B89",
                "editor.gutter.background": "#161e0d90",
                "terminal.background": "#161e0d10",
                "terminal.foreground": "#c4c6c2",
                "terminal.dim_foreground": "#c4c6c2",
                "terminal.bright_foreground": "#c4c6c2",
                "terminal.ansi.black": "#161e0d",
                "terminal.ansi.red": "#6B7B89",
                "terminal.ansi.green": "#AE6389",
                "terminal.ansi.yellow": "#D86D91",
                "terminal.ansi.blue": "#A69D9A",
                "terminal.ansi.magenta": "#D4A0A5",
                "terminal.ansi.cyan": "#D2C0BB",
                "terminal.ansi.white": "#c4c6c2",
                "terminal.ansi.bright_black": "#67705c",
                "terminal.ansi.bright_red": "#6B7B89",
                "terminal.ansi.bright_green": "#AE6389",
                "terminal.ansi.bright_yellow": "#D86D91",
                "terminal.ansi.bright_blue": "#A69D9A",
                "terminal.ansi.bright_magenta": "#D4A0A5",
                "terminal.ansi.bright_cyan": "#D2C0BB",
                "terminal.ansi.bright_white": "#c4c6c2",
                "modified": "#6B7B89",
                "syntax": {
                    "attribute": {
                        "color": "#6B7B89"
                    },
                    "boolean": {
                      "color": "#AE6389"
                    },
                    "comment": {
                      "color": "#67705c"
                    },
                    "comment.doc": {
                      "color": "#67705c"
                    },
                    "constant": {
                      "color": "#AE6389"
                    },
                    "function": {
                      "color": "#D2C0BB"
                    },
                    "keyword": {
                      "color": "#A69D9A"
                    },
                    "number": {
                      "color": "#D4A0A5"
                    },
                    "operator": {
                      "color": "#A69D9A"
                    },
                    "string": {
                      "color": "#6B7B89"
                    },
                    "variable": {
                      "color": "#AE6389"
                    }
                },
                "players": [
                  {
                    "cursor": "#6B7B89",
                    "background": "#161e0d",
                    "selection": "#6B7B8930"
                  }
                ]
            }
        }
    ]
}
